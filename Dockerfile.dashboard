FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit>=1.38.0 \
    requests>=2.31.0 \
    pandas>=2.2.0 \
    confluent-kafka>=2.3.0 \
    docker>=7.1.0 \
    pyyaml>=6.0 \
    pydantic>=2.5.0

COPY services/streamlit ./services/streamlit
COPY config ./config
COPY shared ./shared

ENV PYTHONPATH=/app

EXPOSE 8501

CMD ["streamlit", "run", "services/streamlit/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0"]
